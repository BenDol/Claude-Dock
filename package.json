{
  "name": "claude-dock",
  "version": "1.0.0",
  "description": "Terminal dock for managing multiple Claude Code CLI instances",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "node scripts/fix-node-pty.js && electron-builder install-app-deps",
    "rebuild": "node scripts/fix-node-pty.js && npx @electron/rebuild --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0",
    "react-grid-layout": "^1.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.claude.dock",
    "productName": "Claude Dock",
    "icon": "assets/icon",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/claude-dock-mcp.js",
        "to": "claude-dock-mcp.js"
      }
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}.Portable.${ext}"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal", "arm64"]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
